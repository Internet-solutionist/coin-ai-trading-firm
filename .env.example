# CoIn Environment Variables
LLM_PROVIDER=grok
GROK_API_KEY=your_xai_api_key_here
GROK_MODEL=grok-2-latest

# Gemini (Google) — Swappable brain option (set LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Optional broker (paper first! NEVER use live until 60+ profitable paper days)
ALPACA_API_KEY=your_alpaca_paper_api_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key_here
ALPACA_PAPER=True  # always paper for safety in CoIn policy

# Note: For real Grok LLM in agents (v2.4+), install openai and set key above. Own capable model ready.